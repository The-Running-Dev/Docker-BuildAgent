{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "Build",
        "BuildDocumentation",
        "Setup"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "AppDir": {
          "type": "string",
          "description": "Directory name for the documentation app"
        },
        "ArtifactsDir": {
          "type": "string",
          "description": "Directory where build artifacts are stored"
        },
        "DryRun": {
          "type": "boolean",
          "description": "Enable Dry Run (Skip Push and Tag)"
        },
        "ForceNotifications": {
          "type": "boolean",
          "description": "Force Notifications for Local Builds"
        },
        "ForcePush": {
          "type": "boolean",
          "description": "Force Push/Tag for Local Builds"
        },
        "IsProduction": {
          "type": "boolean",
          "description": "Build for production deployment"
        },
        "NodeTemplateDirPath": {
          "type": "string",
          "description": "Local path where template will be cloned"
        },
        "NodeTemplateRepositoryUrl": {
          "type": "string",
          "description": "Git repository URL for the template"
        },
        "Notifications": {
          "type": "boolean",
          "description": "Enable Notifications for the Build"
        },
        "NotificationsWebHookUrl": {
          "type": "string",
          "description": "WebHook URL for Notifications",
          "default": "Secrets must be entered via 'nuke :secrets [profile]'"
        },
        "PackageManager": {
          "type": "string",
          "description": "Package manager to use (npm, pnpm, yarn)"
        },
        "SkipInstall": {
          "type": "boolean",
          "description": "Skip package manager install step"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
